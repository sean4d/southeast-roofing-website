# Canonical host (PRD §1). southeastroofing.llc is the primary production
# domain; roofs.ms redirects to it. Never hardcode a domain in code.
NEXT_PUBLIC_SITE_URL=https://southeastroofing.llc

# Google Search Console verification token (the "content" value from the
# HTML-tag verification method). Emits <meta name="google-site-verification">
# when set. Leave blank until you verify the property in Search Console.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Sanity CMS — create a free project at sanity.io (see docs/DEPLOYMENT.md),
# then paste the project ID here. The studio at /studio activates once set.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# ── Lead pipeline (see docs/DEPLOYMENT.md §3) ────────────────────────────
# Webhook that receives every form lead as JSON. Point it at a Make.com
# scenario (free tier), a Zapier catch hook, or a Roofr intake endpoint.
LEAD_WEBHOOK_URL=

# Optional email notification for every lead, sent via Resend (free tier).
# LEAD_NOTIFY_EMAIL defaults to the office address in siteConfig.
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=

# Optional "pick a time" button on the form thank-you screen — paste a free
# Google Calendar appointment-schedule link (or Cal.com link).
NEXT_PUBLIC_BOOKING_URL=

# ── Job upload tool at /upload (see the job-relay system) ────────────────
# SECRET. Sanity Editor token (sanity.io → API → Tokens). Lets the /upload
# form save jobs into the gallery. Server-only — never NEXT_PUBLIC.
SANITY_WRITE_TOKEN=
# Passphrase that gates the /upload page. Defaults to "roofroof" if unset.
UPLOAD_PASSWORD=

# ── Social syndication (optional, added per platform as they're connected).
# With none set, uploads still fully post to the website; socials are skipped.
META_PAGE_ACCESS_TOKEN=
GOOGLE_BUSINESS_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=
NEXTDOOR_ACCESS_TOKEN=

# ── Metricool (Google Business Profile + TikTok fan-out) ─────────────────
# The networks Meta's Graph API can't reach go through Metricool. All three
# SECRET/ids are required together; with none set the fan-out is a safe no-op.
METRICOOL_API_TOKEN=
METRICOOL_USER_ID=
METRICOOL_BLOG_ID=
# Set to 1 to ALSO auto-post each new job's finished-work photos to the GBP
# *Photos gallery* (a separate surface from the Posts feed). Leave blank until
# a single test post via POST /api/upload?step=gbp-photo confirms photos land
# in the gallery — see src/lib/metricool.ts (GBP_DATA_FIELD / GBP_PHOTO_TYPE).
METRICOOL_GBP_PHOTOS=
