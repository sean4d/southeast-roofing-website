# Canonical host (PRD §1). southeastroofing.llc is the primary production
# domain; roofs.ms redirects to it. Never hardcode a domain in code.
NEXT_PUBLIC_SITE_URL=https://southeastroofing.llc

# Sanity CMS — create a free project at sanity.io (see docs/DEPLOYMENT.md),
# then paste the project ID here. The studio at /studio activates once set.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# ── Lead pipeline (see docs/DEPLOYMENT.md §3) ────────────────────────────
# Webhook that receives every form lead as JSON. Point it at a Make.com
# scenario (free tier), a Zapier catch hook, or a Roofr intake endpoint.
LEAD_WEBHOOK_URL=

# Optional email notification for every lead, sent via Resend (free tier).
# LEAD_NOTIFY_EMAIL defaults to the office address in siteConfig.
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=

# Optional "pick a time" button on the form thank-you screen — paste a free
# Google Calendar appointment-schedule link (or Cal.com link).
NEXT_PUBLIC_BOOKING_URL=
